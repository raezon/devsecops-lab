# =============== JENKINS CI/CD DOCKER COMPOSE - ENV FILE ===============
# Changez TOUS les mots de passe et secrets avant de déployer en production!
# Version: 2.426+ (LTS)

# ============ PROJECT CONFIGURATION ============
COMPOSE_PROJECT_NAME=jenkins-ci
TZ=Europe/Paris
ENVIRONMENT=development

# ============ POSTGRESQL DATABASE (MariaDB/MySQL optionnel) ============
# PostgreSQL Settings
POSTGRES_DB=jenkins_db
POSTGRES_USER=jenkins_user
POSTGRES_PASSWORD=SuperSecurePostgresPassword2024!
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_VERSION=15-alpine

# PostgreSQL Performance Tuning
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_RANDOM_PAGE_COST=1.1
POSTGRES_EFFECTIVE_IO_CONCURRENCY=200

# MySQL/MariaDB (if preferred)
MYSQL_DATABASE=jenkins_db
MYSQL_USER=jenkins_user
MYSQL_PASSWORD=SuperSecureMySQLPassword2024!
MYSQL_ROOT_PASSWORD=RootPassword2024!
MYSQL_PORT=3306

# ============ JENKINS CORE CONFIGURATION ============
JENKINS_HOME=/var/jenkins_home
JENKINS_AGENT_PORT=50000
JENKINS_JAVA_OVERRIDES=-Xms2g -Xmx4g
JENKINS_EXECUTOR_CORES=4
JENKINS_MAX_EXECUTORS=8
JENKINS_QUIET_PERIOD=5
JENKINS_SCM_POLL_INTERVAL=H/15 * * * *

# JCasC Configuration
CASC_JENKINS_CONFIG=/var/jenkins_home/casc.yaml
JENKINS_CASC_STRICT_MODE=true
JENKINS_CASC_EXPORT_PATH=/var/jenkins_home/jcasc-export

# Jenkins Plugins
JENKINS_OPTS=--prefix=/jenkins
JENKINS_INSTALL_WIZARD_ENABLED=false
JENKINS_PLUGINS_FORCED_UPGRADE=false

# ============ JAVA JVM PERFORMANCE TUNING ============
# Heap Memory Configuration
JAVA_HEAP_MIN=2g
JAVA_HEAP_MAX=4g

# Garbage Collection
JVM_GC_STRATEGY=G1GC
JVM_GC_PARALLEL_GC_THREADS=4
JVM_GC_CONC_GC_THREADS=2
JVM_GC_MAX_GC_PAUSE_MS=200

# Advanced JVM Options
JVM_DISABLE_EXPLICIT_GC=true
JVM_STRING_DEDUPLICATION=true
JVM_TLS_VERSION=TLSv1.2,TLSv1.3
JVM_FILE_ENCODING=UTF-8

# ============ JENKINS SECURITY SETTINGS ============
# CSRF Protection
JENKINS_CSRF_PROTECTION_ENABLED=true
JENKINS_CSRF_EXCLUDE_CLIENT_IP=true

# API Token Security
JENKINS_SECURITY_API_TOKEN_GENERATION_ENABLED=true
JENKINS_SECURITY_API_TOKEN_VERSION=2

# Security Realm
JENKINS_SECURITY_REALM=local
JENKINS_AUTHORIZATION_STRATEGY=roleBased

# Scripting & Sandbox
JENKINS_SCRIPT_SECURITY_ENABLED=true
JENKINS_ALLOW_RUN_SCRIPTS=false

# ============ DOCKER INTEGRATION ============
# Docker Host Configuration
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_API_VERSION=1.40
DOCKER_TLS_VERIFY=0
DOCKER_CERT_PATH=/var/jenkins_home/.docker

# Docker Hub/Registry
DOCKER_REGISTRY=docker.io
DOCKER_HUB_USERNAME=your_dockerhub_username
DOCKER_HUB_PASSWORD=your_dockerhub_password_here
DOCKER_HUB_EMAIL=your_email@example.com

# Docker Build Optimization
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
DOCKER_BUILD_CACHE=true
DOCKER_IMAGE_CLEANUP_ENABLED=true
DOCKER_CONTAINER_CLEANUP_ENABLED=true

# ECR (Amazon Elastic Container Registry)
AWS_ECR_REGISTRY=123456789.dkr.ecr.us-east-1.amazonaws.com
AWS_ECR_USERNAME=AWS
AWS_ECR_PASSWORD=your_ecr_password_here

# ============ GIT / VERSION CONTROL ============
# GitHub Configuration
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_OAUTH_TOKEN=ghp_your_github_oauth_token_here
GITHUB_APP_ID=your_github_app_id_here
GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYourPrivateKeyHere\n-----END RSA PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_API_URL=https://api.github.com
GITHUB_GRAPHQL_URL=https://api.github.com/graphql
GITHUB_ORGANIZATION=your_github_org

# GitLab Configuration
GITLAB_INSTANCE_URL=https://gitlab.com
GITLAB_TOKEN=glpat_your_gitlab_token_here
GITLAB_USERNAME=jenkins_user
GITLAB_EMAIL=jenkins@example.com
GITLAB_WEBHOOK_SECRET=your_gitlab_webhook_secret

# Gitea Configuration
GITEA_URL=https://gitea.example.com
GITEA_TOKEN=your_gitea_token_here
GITEA_USERNAME=jenkins

# Bitbucket Configuration
BITBUCKET_USERNAME=your_bitbucket_username
BITBUCKET_APP_PASSWORD=your_app_password_here
BITBUCKET_WORKSPACE=your_workspace
BITBUCKET_OAUTH_CLIENT_ID=your_client_id
BITBUCKET_OAUTH_CLIENT_SECRET=your_client_secret

# Git User Configuration
GIT_USER_NAME=Jenkins CI/CD
GIT_USER_EMAIL=jenkins@example.com
GIT_AUTHOR_NAME=Jenkins CI
GIT_AUTHOR_EMAIL=jenkins@example.com
GIT_COMMITTER_NAME=Jenkins CI
GIT_COMMITTER_EMAIL=jenkins@example.com

# SSH Key Configuration
SSH_PRIVATE_KEY_FILE=/var/jenkins_home/.ssh/id_rsa
SSH_PRIVATE_KEY_PASSPHRASE=your_ssh_passphrase_here
SSH_KNOWN_HOSTS_FILE=/var/jenkins_home/.ssh/known_hosts
SSH_AGENT_SOCK=/tmp/ssh-agent.sock

# ============ EMAIL & NOTIFICATIONS ============
# SMTP Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_AUTH_ENABLED=true
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password_here
EMAIL_FROM=jenkins@example.com
EMAIL_REPLY_TO=jenkins@example.com
EMAIL_SMTP_DEBUG=false

# Alternative SMTP (Office365)
OFFICE365_SMTP_HOST=smtp.office365.com
OFFICE365_SMTP_PORT=587
OFFICE365_EMAIL=your_office365_email@company.com
OFFICE365_PASSWORD=your_office365_password

# Alternative SMTP (SendGrid)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@example.com

# Alternative SMTP (Mailgun)
MAILGUN_API_KEY=key-your_mailgun_api_key_here
MAILGUN_DOMAIN=mg.example.com
MAILGUN_SMTP_HOST=smtp.mailgun.org
MAILGUN_SMTP_PORT=587

# Email Templates
EMAIL_SUBJECT_PREFIX=[Jenkins]
EMAIL_INCLUDE_LOGS=true
EMAIL_INCLUDE_CONSOLE_OUTPUT=false
EMAIL_MAX_ATTACHMENT_SIZE=10485760

# ============ SLACK NOTIFICATIONS ============
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_APP_TOKEN=xapp-your-slack-app-token-here
SLACK_TEAM_DOMAIN=your-slack-workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#jenkins
SLACK_CHANNEL_FAILURE=#jenkins-alerts
SLACK_CHANNEL_SUCCESS=#jenkins-builds
SLACK_BOT_USER=@jenkins-bot
SLACK_SEND_AS_BOT=true
SLACK_COMMIT_INFO_ENABLED=true
SLACK_INCLUDE_TEST_SUMMARY=true
SLACK_INCLUDE_CUSTOM_MESSAGE=true

# ============ ROCKETCHAT NOTIFICATIONS ============
ROCKETCHAT_WEBHOOK=https://chat.example.com/hooks/integration_id/token
ROCKETCHAT_API_URL=https://chat.example.com
ROCKETCHAT_USERNAME=jenkins_bot
ROCKETCHAT_PASSWORD=rocketchat_password_here
ROCKETCHAT_AUTH_TOKEN=your_auth_token
ROCKETCHAT_USER_ID=your_user_id
ROCKETCHAT_CHANNEL=#jenkins

# ============ MATTERMOST NOTIFICATIONS ============
MATTERMOST_WEBHOOK=https://mattermost.example.com/hooks/incoming_webhook_id
MATTERMOST_CHANNEL=jenkins
MATTERMOST_USERNAME=jenkins-bot

# ============ JENKINS AGENTS CONFIGURATION ============
# Agent Main
JENKINS_AGENT_SECRET=your_agent_secret_key_here_change_it
JENKINS_AGENT_NAME=docker-agent
JENKINS_AGENT_WORKDIR=/home/jenkins/agent
JENKINS_AGENT_EXECUTORS=4
JENKINS_AGENT_LABELS=docker,linux,builds
JENKINS_AGENT_MODE=exclusive
JENKINS_AGENT_CONNECT_TIMEOUT=60
JENKINS_AGENT_DESCRIPTION=Docker-based Jenkins Agent

# Agent Kubernetes (optional)
KUBERNETES_NAMESPACE=jenkins
KUBERNETES_SERVICE_ACCOUNT=jenkins
KUBERNETES_CLOUD_NAME=kubernetes
KUBERNETES_POD_RETENTION=Never
KUBERNETES_JENKINS_URL=http://jenkins:8080

# ============ NGINX REVERSE PROXY CONFIGURATION ============
NGINX_SERVER_NAME=jenkins.example.com
NGINX_UPSTREAM_SERVER=jenkins
NGINX_UPSTREAM_PORT=8080
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024
NGINX_KEEPALIVE_TIMEOUT=65
NGINX_CLIENT_MAX_BODY_SIZE=100M
NGINX_GZIP_ENABLED=true
NGINX_GZIP_LEVEL=6
NGINX_GZIP_TYPES=text/plain text/css text/xml application/json application/javascript

# Nginx Cache
NGINX_CACHE_ENABLED=true
NGINX_CACHE_SIZE=10m
NGINX_CACHE_TIME=1h
NGINX_CACHE_INACTIVE=60m

# ============ SSL/TLS CERTIFICATES (NGINX) ============
SSL_ENABLED=true
SSL_CERTIFICATE_PATH=/etc/nginx/ssl/certificate.crt
SSL_PRIVATE_KEY_PATH=/etc/nginx/ssl/private.key
SSL_CERTIFICATE_CHAIN=/etc/nginx/ssl/chain.crt
SSL_DHPARAM=/etc/nginx/ssl/dhparam.pem

# SSL Configuration
SSL_PROTOCOLS=TLSv1.2 TLSv1.3
SSL_CIPHERS=ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256
SSL_PREFER_SERVER_CIPHERS=on
SSL_SESSION_CACHE=shared:SSL:10m
SSL_SESSION_TIMEOUT=10m
SSL_SESSION_TICKETS=off
SSL_OCSP_STAPLING=off

# Let's Encrypt / Certbot
CERTBOT_EMAIL=admin@example.com
CERTBOT_DOMAIN=jenkins.example.com
CERTBOT_RENEWAL_ENABLED=true

# ============ DATABASE CONNECTIVITY ============
# Connection Pool
DATABASE_CONNECTION_POOL_SIZE=20
DATABASE_CONNECTION_MAX_IDLE_TIME=900000
DATABASE_CONNECTION_TIMEOUT=30000

# Query Optimization
DATABASE_STATEMENT_CACHE_SIZE=250
DATABASE_PREPARE_THRESHOLD=5

# ============ LOGGING & LOG AGGREGATION ============
LOG_LEVEL=INFO
JENKINS_LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=/var/jenkins_home/logs/jenkins.log
LOG_FILE_MAX_SIZE=100M
LOG_FILE_MAX_BACKUPS=10
LOG_RETENTION_DAYS=30

# External Logging (ELK/Splunk)
LOG_AGGREGATOR_ENABLED=false
ELK_ELASTICSEARCH_HOST=elasticsearch
ELK_ELASTICSEARCH_PORT=9200
SPLUNK_HEC_TOKEN=your_splunk_hec_token
SPLUNK_HEC_URL=https://splunk.example.com:8088

# ============ MONITORING & OBSERVABILITY ============
# Prometheus Metrics
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_PORT=9100
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_SCRAPE_INTERVAL=15s

# Grafana Integration
GRAFANA_URL=http://grafana:3000
GRAFANA_API_KEY=your_grafana_api_key_here
GRAFANA_DATASOURCE_NAME=Prometheus

# ============ APPLICATION PERFORMANCE MONITORING ============
# Datadog
DATADOG_ENABLED=false
DATADOG_API_KEY=your_datadog_api_key_here
DATADOG_APP_KEY=your_datadog_app_key_here
DATADOG_SITE=datadoghq.com
DATADOG_SERVICE=jenkins
DATADOG_ENV=production
DATADOG_LOGS_INJECTION=true

# New Relic
NEWRELIC_ENABLED=false
NEW_RELIC_API_KEY=your_new_relic_api_key
NEW_RELIC_ACCOUNT_ID=your_account_id
NEW_RELIC_LICENSE_KEY=your_license_key
NEW_RELIC_APP_NAME=jenkins-ci

# Dynatrace
DYNATRACE_ENABLED=false
DYNATRACE_ENVIRONMENT_ID=your_environment_id
DYNATRACE_API_TOKEN=your_api_token

# ============ SECURITY & AUTHENTICATION ============
# LDAP / Active Directory
LDAP_ENABLED=false
LDAP_SERVER=ldap://example.com
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_USE_TLS=false
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=ldap_password_here
LDAP_BASE_DN=dc=example,dc=com
LDAP_USER_SEARCH_BASE=ou=users,dc=example,dc=com
LDAP_USER_SEARCH_FILTER=(uid={0})
LDAP_GROUP_SEARCH_BASE=ou=groups,dc=example,dc=com
LDAP_GROUP_SEARCH_FILTER=(memberUid={0})
LDAP_MANAGER_DN=cn=admin,dc=example,dc=com
LDAP_MANAGER_PASSWORD=manager_password_here

# SAML / Single Sign-On
SAML_ENABLED=false
SAML_IDP_METADATA_URL=https://idp.example.com/metadata
SAML_ENTITY_ID=https://jenkins.example.com
SAML_BINDING=urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST
SAML_DISPLAY_NAME_ATTRIBUTE=displayName
SAML_EMAIL_ATTRIBUTE=email
SAML_USER_NAME_ATTRIBUTE=uid

# OAuth2 / OIDC
OAUTH2_ENABLED=false
OAUTH2_CLIENT_ID=your_client_id
OAUTH2_CLIENT_SECRET=your_client_secret
OAUTH2_AUTHORIZATION_URL=https://idp.example.com/oauth/authorize
OAUTH2_TOKEN_URL=https://idp.example.com/oauth/token
OAUTH2_USERINFO_URL=https://idp.example.com/oauth/userinfo
OAUTH2_SCOPES=openid profile email

# ============ INTEGRATION SERVICES ============
# JIRA Integration
JIRA_URL=https://jira.example.com
JIRA_USERNAME=jenkins
JIRA_API_TOKEN=jira_api_token_here
JIRA_PROJECT_KEY=ENG
JIRA_ISSUE_TRANSITION_ENABLED=true

# SonarQube Code Quality
SONAR_HOST_URL=http://sonarqube:9000
SONAR_LOGIN=admin
SONAR_PASSWORD=sonar_password_here
SONAR_ORGANIZATION=my-organization
SONAR_ANALYSIS_MODE=publish
SONAR_QUALITY_GATE_WAIT=true

# Artifactory / Maven Repository
ARTIFACTORY_URL=https://artifactory.example.com/artifactory
ARTIFACTORY_USERNAME=jenkins
ARTIFACTORY_API_KEY=artifactory_api_key_here
ARTIFACTORY_REPO=libs-release
ARTIFACTORY_REPO_SNAPSHOT=libs-snapshot

# Nexus Repository
NEXUS_URL=https://nexus.example.com
NEXUS_USERNAME=jenkins
NEXUS_PASSWORD=nexus_password_here
NEXUS_REPOSITORY=releases
NEXUS_SNAPSHOT_REPOSITORY=snapshots

# npm Registry
NPM_REGISTRY=https://registry.npmjs.org
NPM_TOKEN=npm_your_token_here
NPM_SCOPE=@yourorg
NPM_ALWAYS_AUTH=true

# PyPI / Python Packages
PYPI_REPOSITORY_URL=https://pypi.org/simple/
PYPI_USERNAME=__token__
PYPI_PASSWORD=pypi_token_here
PYPI_TEST_REPOSITORY_URL=https://test.pypi.org/legacy/

# ============ CLOUD PLATFORMS ============
# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SESSION_TOKEN=your_session_token
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default

# AWS Services
AWS_S3_BUCKET=jenkins-artifacts
AWS_S3_REGION=us-east-1
AWS_LAMBDA_FUNCTION=jenkins-function
AWS_EC2_INSTANCES_ENABLED=true
AWS_ECS_ENABLED=true
AWS_ECS_CLUSTER=jenkins-cluster
AWS_CODECOMMIT_ENABLED=true
AWS_CODEPIPELINE_ENABLED=true

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
AZURE_TENANT_ID=your_tenant_id
AZURE_RESOURCE_GROUP=jenkins-rg
AZURE_STORAGE_ACCOUNT=jenkinsaccount
AZURE_CONTAINER_REGISTRY=jenkinsregistry.azurecr.io

# Google Cloud Configuration
GCP_PROJECT_ID=your_project_id
GCP_SERVICE_ACCOUNT_EMAIL=jenkins@project.iam.gserviceaccount.com
GCP_SERVICE_ACCOUNT_KEY_PATH=/var/jenkins_home/.gcp/service-account-key.json
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
GCP_GCR_REGISTRY=gcr.io/your_project_id

# ============ CONTAINER ORCHESTRATION ============
# Kubernetes / K8s
KUBERNETES_ENABLED=false
KUBERNETES_CLUSTER_URL=https://kubernetes.default.svc.cluster.local
KUBERNETES_NAMESPACE=jenkins
KUBERNETES_SERVICE_ACCOUNT=jenkins
KUBERNETES_CA_CRT_PATH=/var/run/secrets/kubernetes.io/serviceaccount/ca.crt
KUBERNETES_TOKEN_PATH=/var/run/secrets/kubernetes.io/serviceaccount/token

# Docker Swarm
DOCKER_SWARM_ENABLED=false
DOCKER_SWARM_MANAGER=swarm-manager:2377

# ============ BUILD TOOLS & RUNTIMES ============
# Maven
MAVEN_VERSION=3.8.1
MAVEN_HOME=/opt/maven
MAVEN_REPO_LOCAL=/var/jenkins_home/.m2

# Gradle
GRADLE_VERSION=7.6
GRADLE_HOME=/opt/gradle

# Node.js / npm
NODE_VERSION=18.13.0
NPM_VERSION=8.19.3
NODE_PATH=/usr/local/lib/node_modules

# Python
PYTHON_VERSION=3.11
PIP_INDEX_URL=https://pypi.org/simple/
PIP_EXTRA_INDEX_URL=https://test.pypi.org/simple/

# Java
JAVA_HOME=/usr/local/openjdk-17
JAVA_VERSION=17
JAVA_TOOL_OPTIONS=-Dfile.encoding=UTF-8

# Go
GO_VERSION=1.19
GOPATH=/opt/go
GOROOT=/usr/local/go

# .NET / C#
DOTNET_VERSION=7.0
DOTNET_HOME=/usr/local/dotnet

# ============ TESTING & QUALITY ASSURANCE ============
# JUnit Report
JUNIT_REPORT_PATH=**/target/surefire-reports/TEST-*.xml
JUNIT_ALLOW_EMPTY_RESULTS=false

# Code Coverage (JaCoCo)
JACOCO_REPORT_PATH=**/target/site/jacoco/

# Performance Tests
PERFORMANCE_REPORT_PATH=**/jmeter-results.jtl

# Selenium / WebDriver
SELENIUM_HUB_URL=http://selenium-hub:4444
SELENIUM_CHROME_ENABLED=true
SELENIUM_FIREFOX_ENABLED=true

# ============ ARTIFACT MANAGEMENT ============
ARTIFACT_MANAGER_ENABLED=true
ARTIFACTS_PATH=/var/jenkins_home/artifacts
ARTIFACTS_RETENTION_DAYS=30
ARTIFACTS_DISK_QUOTA_GB=100

# ============ BACKUP & DISASTER RECOVERY ============
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_TIME=02:00
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=jenkins-backups
BACKUP_S3_PREFIX=jenkins/

# ============ SYSTEM & RESOURCE LIMITS ============
# Memory & CPU
MEMORY_LIMIT=8g
MEMORY_RESERVATION=4g
CPUS_LIMIT=4
CPUS_RESERVATION=2

# Disk Space
JENKINS_HOME_DISK_QUOTA_GB=500
WORKSPACE_DISK_QUOTA_GB=200
ARTIFACT_DISK_QUOTA_GB=100

# ============ NETWORK & CONNECTIVITY ============
# Proxy Settings (if behind corporate proxy)
HTTP_PROXY=http://proxy.example.com:8080
HTTPS_PROXY=http://proxy.example.com:8080
NO_PROXY=localhost,127.0.0.1,*.example.com,jenkins,postgres,nginx
HTTP_PROXY_USER=proxy_user
HTTP_PROXY_PASSWORD=proxy_password

# DNS Configuration
DNS_SERVERS=8.8.8.8 8.8.4.4
DNS_SEARCH=example.com

# Network Timeouts
CONNECTION_TIMEOUT_SECONDS=60
READ_TIMEOUT_SECONDS=300
WRITE_TIMEOUT_SECONDS=300

# ============ ADVANCED CONFIGURATION ============
# Jenkins URL
JENKINS_URL=http://jenkins:8080
JENKINS_PUBLIC_URL=https://jenkins.example.com
JENKINS_CONTEXT_PATH=/

# Jenkins Options
JENKINS_INSTALL_WIZARD_ENABLED=false
JENKINS_PLUGINS_FORCED_UPGRADE=false
JENKINS_DISABLE_CSRF_CRUMB=false
JENKINS_SLAVES_PORT=50000

# Groovy Scripts
GROOVY_HOOK_SCRIPTS_ENABLED=true
GROOVY_SCRIPTS_PATH=/usr/local/etc/jenkins/init.groovy.d/

# ============ DEVELOPMENT / DEBUG MODE ============
DEBUG_ENABLED=false
DEBUG_PORT=5005
DEBUG_SUSPEND=false
VERBOSE_LOGGING=false
JENKINS_DEBUG=false